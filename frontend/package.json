{
    "name": "resulter",
    "type": "module",
    "version": "4.9.3",
    "private": true,
    "packageManager": "pnpm@11.11.0",
    "scripts": {
        "dev": "node --localstorage-file=.node-localstorage node_modules/vite/bin/vite.js --mode development",
        "build": "nx exec -- echo 'Ran type-check and build-only'",
        "preview": "nx vite:preview",
        "build-only": "nx vite:build --mode production",
        "type-check": "vue-tsc --noEmit --project tsconfig.typecheck.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "clean": "rm -rf dist",
        "cleanjs": "find src -type f \\( -name '*.js' -o -name '*.d.ts' \\) ! -name 'vue-i18n.d.ts' ! -name 'shims-vue.d.ts' -delete",
        "bundle-visualizer": "pnpx vite-bundle-visualizer",
        "test:all": "pnpm test:unit && pnpm test:e2e",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest watch",
        "test:unit:ui": "vitest --ui",
        "test:unit:coverage": "vitest run --coverage",
        "test:unit:file": "vitest run",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:debug": "playwright test --debug",
        "test:e2e:chromium": "playwright test --project=chromium",
        "test:e2e:firefox": "playwright test --project=firefox",
        "test:e2e:webkit": "playwright test --project=webkit",
        "test:e2e:auth": "playwright test auth-setup.ts",
        "test:e2e:auth:headed": "playwright test auth-setup.ts --headed",
        "test:e2e:auth:debug": "playwright test auth-setup.ts --debug",
        "test:e2e:main": "playwright test main.spec.ts",
        "test:e2e:event": "playwright test event.spec.ts",
        "test:e2e:event-form": "playwright test event-form.spec.ts",
        "test:e2e:report": "playwright show-report",
        "test:e2e:trace": "playwright show-trace",
        "test:e2e:check": "bash scripts/run-e2e.sh"
    },
    "dependencies": {
        "@base2/pretty-print-object": "^1.0.2",
        "@fontsource/fraunces": "^5.2.9",
        "@fontsource/manrope": "^5.2.8",
        "@primeuix/themes": "^2.0.3",
        "@tanstack/vue-query": "^5.101.0",
        "@tanstack/vue-query-devtools": "^6.1.34",
        "@vueuse/core": "^14.3.0",
        "axios": "^1.18.0",
        "cors": "^2.8.6",
        "dompurify": "^3.4.10",
        "flag-icons": "^7.5.0",
        "moment": "^2.30.1",
        "moment-timezone": "^0.6.2",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "primeflex": "^4.0.0",
        "primeicons": "^7.0.0",
        "primevue": "^4.5.5",
        "spring-filter-query-builder": "^1.1.1",
        "vue": "^3.5.38",
        "vue-i18n": "^11.4.5",
        "vue-pdf-embed": "^2.1.4",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^9.0.0",
        "@intlify/unplugin-vue-i18n": "^11.2.3",
        "@nx/eslint": "22.7.5",
        "@nx/playwright": "22.7.5",
        "@nx/vite": "22.7.5",
        "@nx/vue": "22.7.5",
        "@nx/web": "22.7.5",
        "@pinia/testing": "^1.0.3",
        "@playwright/test": "^1.61.0",
        "@rollup/plugin-dynamic-import-vars": "^2.1.5",
        "@rushstack/eslint-patch": "^1.16.1",
        "@tailwindcss/postcss": "^4.3.1",
        "@tsconfig/node24": "^24.0.4",
        "@types/jsdom": "^28.0.3",
        "@types/moment-duration-format": "^2.2.7",
        "@types/node": "^25.9.3",
        "@unocss/eslint-plugin": "^66.7.2",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/browser-playwright": "^4.1.9",
        "@vitest/coverage-v8": "^4.1.9",
        "@vitest/ui": "^4.1.9",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/eslint-config-typescript": "^14.8.0",
        "@vue/test-utils": "^2.4.11",
        "@vue/tsconfig": "^0.9.1",
        "autoprefixer": "^10.5.0",
        "axe-core": "^4.12.1",
        "baseline-browser-mapping": "^2.10.37",
        "dotenv": "^17.4.2",
        "eslint": "^10.5.0",
        "eslint-plugin-format": "^2.0.1",
        "eslint-plugin-vue": "^10.9.2",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.7",
        "npm-run-all2": "^9.0.2",
        "nx": "22.7.5",
        "oxfmt": "^0.58.0",
        "playwright": "^1.61.0",
        "postcss": "^8.5.15",
        "prettier": "^3.8.4",
        "sass": "^1.101.0",
        "simple-git-hooks": "^2.13.1",
        "tailwindcss": "^4.3.1",
        "typescript": "~6.0.3",
        "unocss": "^66.7.2",
        "vite": "^8.0.16",
        "vite-plugin-vue-devtools": "^8.1.3",
        "vitest": "^4.1.9",
        "vitest-browser-vue": "^2.1.0",
        "vue-mess-detector": "^0.68.1",
        "vue-tsc": "^3.3.5"
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm lint-staged",
        "pre-push": "bash ./pre-push-trivy.sh"
    },
    "lint-staged": {
        "*": "eslint --fix"
    },
    "nx": {}
}
